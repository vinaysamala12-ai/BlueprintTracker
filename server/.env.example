# Server
PORT=5000
CLIENT_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/approval-workflow

# App URL (used in approval email links)
APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Microsoft 365 — Graph API (sendMail)
# Azure AD App Registration required.
# Permission needed: Mail.Send (Application, admin-consented)
# ─────────────────────────────────────────────
MS365_TENANT_ID=your-tenant-id
MS365_CLIENT_ID=your-client-id
MS365_CLIENT_SECRET=your-client-secret
MS365_FROM_EMAIL=no-reply@yourcompany.com
MS365_FROM_NAME=Document Approval System

# ─────────────────────────────────────────────
# SharePoint / OneDrive — Graph API
# Same App Registration can be reused.
# Permissions needed: Files.Read.All, Sites.Read.All (Application, admin-consented)
# ─────────────────────────────────────────────
GRAPH_TENANT_ID=your-tenant-id
GRAPH_CLIENT_ID=your-client-id
GRAPH_CLIENT_SECRET=your-client-secret

# SharePoint (set SHAREPOINT_SITE_URL to enable)
SHAREPOINT_SITE_URL=https://yourcompany.sharepoint.com/sites/yoursite
SHAREPOINT_LIBRARY=Documents

# OneDrive (leave blank to use default drive)
ONEDRIVE_DRIVE_ID=

# ─────────────────────────────────────────────
# Scheduler defaults (overridden by DB config)
# ─────────────────────────────────────────────
SCHEDULER_CRON=0 * * * *
REMINDER_INTERVAL_HOURS=24
MAX_REMINDERS=3
