# ── MCP Server settings ───────────────────────────────────────────────────────
SERVER_HOST=localhost
SERVER_PORT=8001
MCP_BASE_PATH=blueprint-tracker
LOG_LEVEL=INFO

# ── MCP auth (optional — protects the MCP server itself) ─────────────────────
# When set, all MCP clients must supply this key in the configured header.
# Leave unset for local development (auth bypassed).
# MCP_MASTER_API_KEY=change-me
# MCP_MASTER_API_KEY_NAME=x-api-key

# ── BlueprintTracker backend API ──────────────────────────────────────────────
# URL of the running BlueprintTracker Express server
BLUEPRINT_API_URL=http://localhost:5000

# Admin credentials used by the MCP server to authenticate with the API
BLUEPRINT_USERNAME=admin
BLUEPRINT_PASSWORD=your-admin-password

# ── MCP tool-set configuration file ──────────────────────────────────────────
MCP_CONFIGURATIONS_FILE=mcp-configurations.json

# ── Tuning (optional) ─────────────────────────────────────────────────────────
# TOOL_TIMEOUT_SECONDS=30
# HTTP_CLIENT_TIMEOUT_SECONDS=30
# RESPONSE_MAX_BYTES=1000000
